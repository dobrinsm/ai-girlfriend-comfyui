# AI Girlfriend Backend Configuration

# App Settings
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ComfyUI Connection
COMFYUI_URL=http://localhost:8188
COMFYUI_WS_URL=ws://localhost:8188/ws
WORKFLOW_DIR=../workflows
OUTPUT_DIR=./outputs

# Ollama Connection (set to service name in Docker Compose)
# Local: http://localhost:11434 (default)
# Docker: http://ollama:11434
OLLAMA_HOST=http://localhost:11434

# Model Settings
VLM_MODEL=qwen2-vl-7b
LLM_MODEL=llama3.2:7b
TTS_MODEL=cosyvoice3
TTS_VOICE_ID=friendly_female

# Memory Settings
MEMORY_DB_PATH=./data/memory.db
MAX_MEMORY_ITEMS=50

# Generation Settings
DEFAULT_CFG=3.5
DEFAULT_STEPS=6
WAVESPEED_CACHE=true
CACHE_STRENGTH=0.15

# Performance
MAX_CONCURRENT_GENERATIONS=2
REQUEST_TIMEOUT=300

# Optional: Redis for scaling
# REDIS_URL=redis://localhost:6379/0

# Security (set in production)
# API_KEY=your-secret-api-key
# ALLOWED_ORIGINS=["https://yourdomain.com"]
