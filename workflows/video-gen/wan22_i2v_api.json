{
  "1": {
    "inputs": {"ckpt_name": "wan21_i2v_720p_fp8_bf16.safetensors"},
    "class_type": "CheckpointLoaderSimple"
  },
  "2": {
    "inputs": {"image": "input_avatar.png"},
    "class_type": "LoadImage"
  },
  "3": {
    "inputs": {"clip": ["1", 1], "text": "woman speaking naturally, subtle head movements, realistic facial expressions, maintaining eye contact, natural lighting, 720p quality"},
    "class_type": "CLIPTextEncode"
  },
  "4": {
    "inputs": {"clip": ["1", 1], "text": "blurry, distorted, unnatural movements, robotic, glitch, artifacts"},
    "class_type": "CLIPTextEncode"
  },
  "5": {
    "inputs": {"image": ["2", 0], "method": "lanczos", "width": 1280, "height": 720, "crop": "center"},
    "class_type": "ImageScale"
  },
  "6": {
    "inputs": {"pixels": ["5", 0], "vae": ["1", 2]},
    "class_type": "VAEEncode"
  },
  "8": {
    "inputs": {"model": ["1", 0]},
    "class_type": "WaveSpeed_FirstBlockCache"
  },
  "9": {
    "inputs": {"model": ["8", 0], "strength": 0.15, "mode": "balanced"},
    "class_type": "WaveSpeed_CacheSettings"
  },
  "10": {
    "inputs": {"model": ["9", 0], "positive": ["3", 0], "negative": ["4", 0], "latent_image": ["6", 0], "seed": 12345, "steps": 6, "cfg": 3.5, "sampler_name": "euler", "scheduler": "simple", "denoise": 1},
    "class_type": "KSampler"
  },
  "11": {
    "inputs": {"samples": ["10", 0], "vae": ["1", 2]},
    "class_type": "VAEDecode"
  },
  "12": {
    "inputs": {"images": ["11", 0], "format": "video/h264-mp4", "fps": 24, "lossless": false, "quality": 75, "save_metadata": true},
    "class_type": "VHS_VideoCombine"
  },
  "13": {
    "inputs": {"images": ["11", 0]},
    "class_type": "SaveImage",
    "_meta": {"title": "Save Video Frames"}
  }
}
